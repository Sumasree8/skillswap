# ─── SkillSwap Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values before running the server.

# Server
PORT=5000
NODE_ENV=development

# MongoDB — use Atlas connection string for production
# Local:   mongodb://localhost:27017/skillswap
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/skillswap
MONGO_URI=mongodb://localhost:27017/skillswap

# JWT — REQUIRED. Use a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
